# ============================================================
# NutriTrack AI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── Google Gemini API ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
# Get your key: https://aistudio.google.com/app/apikey
# Free tier is sufficient for development and demo

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
# Found in: Supabase Dashboard > Project Settings > API > Project URL

SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Found in: Supabase Dashboard > Project Settings > API > anon public
# Safe to expose in browser/frontend

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Found in: Supabase Dashboard > Project Settings > API > service_role
# ⚠️  SECRET — Never expose this in frontend code or commit to git

# ── Next.js Public Variables (accessible in browser) ─────────
NEXT_PUBLIC_API_URL=http://localhost:5000
# Local dev: http://localhost:5000
# Docker:    /   (nginx handles routing on same origin)
# Cloud Run: /   (nginx handles routing)

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Flask / Backend ──────────────────────────────────────────
FLASK_ENV=development
# Set to 'production' in Cloud Run

FLASK_SECRET_KEY=change_this_to_a_long_random_string_in_production
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"

PORT=5000
# Cloud Run will override this with 8080 automatically

# ── App Defaults ─────────────────────────────────────────────
DEFAULT_DAILY_CALORIE_GOAL=2000
DEFAULT_DAILY_BUDGET_USD=30
